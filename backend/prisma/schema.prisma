generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(OPERATOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  auditLogs AuditLog[]

  @@map("users")
}

model Device {
  id             String       @id @default(uuid())
  name           String
  model          String
  serialNumber   String       @unique @map("serial_number")
  ipAddress      String       @map("ip_address")
  port           Int          @default(443)
  login          String       @default("admin")
  password       String
  firmwareVersion String?     @map("firmware_version")
  status         DeviceStatus @default(OFFLINE)
  lastSyncAt     DateTime?    @map("last_sync_at")
  lastHeartbeat  DateTime?    @map("last_heartbeat")
  locationId     String?      @map("location_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  location       Location?    @relation(fields: [locationId], references: [id])
  accessRules    AccessRule[]
  people         PersonDevice[]
  auditLogs      AuditLog[]
  accessLogs     AccessLog[]

  @@map("devices")
}

model Location {
  id        String   @id @default(uuid())
  name      String
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  devices   Device[]

  @@map("locations")
}

model Person {
  id             String   @id @default(uuid())
  name           String
  registration   String   @unique
  cardNumber     String?  @map("card_number")
  pinCode        String?  @map("pin_code")
  active         Boolean  @default(true)
  groupId        String?  @map("group_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  group          PersonGroup? @relation(fields: [groupId], references: [id])
  devices        PersonDevice[]
  accessLogs     AccessLog[]

  @@map("people")
}

model PersonGroup {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  people    Person[]
  accessRules AccessRule[]

  @@map("person_groups")
}

model PersonDevice {
  id        String   @id @default(uuid())
  personId  String   @map("person_id")
  deviceId  String   @map("device_id")
  synced    Boolean  @default(false)
  syncedAt  DateTime? @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")

  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([personId, deviceId])
  @@map("person_devices")
}

model AccessRule {
  id          String   @id @default(uuid())
  name        String
  deviceId    String   @map("device_id")
  groupId     String?  @map("group_id")
  timeZone    String   @default("*") @map("time_zone")
  daysOfWeek  String   @default("1,2,3,4,5,6,7") @map("days_of_week")
  startTime   String   @default("00:00") @map("start_time")
  endTime     String   @default("23:59") @map("end_time")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  device      Device      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  group       PersonGroup? @relation(fields: [groupId], references: [id])

  @@map("access_rules")
}

model AccessLog {
  id         String       @id @default(uuid())
  deviceId   String       @map("device_id")
  personId   String?      @map("person_id")
  event      AccessEvent
  method     AccessMethod?
  accessedAt DateTime     @default(now()) @map("accessed_at")
  details    String?

  device     Device       @relation(fields: [deviceId], references: [id])
  person     Person?      @relation(fields: [personId], references: [id])

  @@index([deviceId, accessedAt])
  @@map("access_logs")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  deviceId   String?  @map("device_id")
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  details    String?
  createdAt  DateTime @default(now()) @map("created_at")

  user       User?    @relation(fields: [userId], references: [id])
  device     Device?  @relation(fields: [deviceId], references: [id])

  @@index([createdAt])
  @@map("audit_logs")
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  ERROR
  SYNCING
}

enum AccessEvent {
  GRANTED
  DENIED
  DOOR_OPENED
  DOOR_CLOSED
  ALARM
}

enum AccessMethod {
  CARD
  PIN
  FINGERPRINT
  FACIAL
  QR_CODE
  REMOTE
}
